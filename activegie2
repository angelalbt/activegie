function launchSession(sessId, phaseIdx, weekIdx, sessIdx){
  const sess=SESSIONS.find(s=>s.id===sessId)||YOGA_SESSIONS.find(s=>s.id===sessId);
  if(sess.type==='run'){
    go('workout',document.getElementById('nav-workout'));
    openRunLog();
    return;
  }
  if(sess.type==='yoga'){
    go('bienetre',document.getElementById('nav-bienetre'));
    return;
  }
  activeProgKey={phaseIdx,weekIdx,sessIdx};
  startWeightsSession(sess);
}

function startNextSession(){
  const sess2=getSessForWeek(curPhaseIdx,curWeek);
  const nextIdx=sess2.findIndex((_,i)=>!isSessionDone(curPhaseIdx,curWeek,i));
  if(nextIdx<0){alert('Toutes les séances de la semaine sont faites ! 🎉');return;}
  launchSession(sess2[nextIdx].id,curPhaseIdx,curWeek,nextIdx);
}

