// ── CHARGE HELPERS ────────────────────────────────────────────
function getLastSets(name){
  for(const w of workouts){
    if(w.type!=='weights'||!w.exercises) continue;
    const ex=w.exercises.find(e=>e.name===name);
    if(ex?.sets?.length) return ex.sets;
  }
  return null;
}

function getChargeHistory(name){
  const out=[];
  [...workouts].reverse().forEach(w=>{
    if(w.type!=='weights'||!w.exercises) return;
    const ex=w.exercises.find(e=>e.name===name);
    if(!ex?.sets) return;
    const kg=Math.max(...ex.sets.map(s=>s.kg||0));
    if(kg>0) out.push({date:w.date,kg});
  });
  return out;
}

function addExercise(name='',sets=3,reps=10,tip=''){
  const c=document.getElementById('ex-container');
  const id='ex'+Date.now()+Math.random().toString(36).slice(2);
  const div=document.createElement('div'); div.className='ex-card2';
  const n=c.children.length+1;
  const lastSets=name?getLastSets(name):null;
  const lastMax=lastSets?Math.max(...lastSets.map(s=>s.kg||0)):0;
  const lastHint=lastMax>0
    ?`<div style="font-size:11px;color:var(--muted);margin-top:3px">↩ Dernière fois : <strong style="color:var(--text)">${lastMax} kg</strong></div>`
    :'';
  div.innerHTML=`<div class="ex-hdr2">
    <div class="ex-num">${n}</div>
    <div class="ex-info">
      <input style="background:none;border:none;font-family:var(--sans);font-size:15px;font-weight:800;color:var(--text);width:100%;outline:none" value="${name}" placeholder="Exercice...">
      ${lastHint}
      ${tip?`<div class="ex-tip2">💡 ${tip}</div>`:''}
    </div>
    <button class="ex-del" onclick="this.closest('.ex-card2').remove()">×</button>
  </div>
  <div class="sets-area">
    <div style="display:grid;grid-template-columns:30px 1fr 1fr 36px;gap:8px;padding-bottom:4px">
      <div style="font-size:10px;color:var(--muted);font-weight:700;text-align:center">#</div>
      <div style="font-size:10px;color:var(--muted);font-weight:700;text-align:center">REPS</div>
      <div style="font-size:10px;color:var(--muted);font-weight:700;text-align:center">KG</div>
      <div></div>
    </div>
    <div id="sets-${id}"></div>
  </div>
  <button class="add-set2" onclick="addSet('${id}')">+ Set</button>`;
  c.appendChild(div);
  const n2=typeof sets==='number'?sets:3;
  for(let i=0;i<n2;i++){
    const prev=lastSets?.[i];
    addSet(id, prev?.reps||reps, prev?.kg||'');
  }
}

function addSet(id,reps='',kg=''){
  const tb=document.getElementById('sets-'+id);
  const n=tb.children.length+1;
  const row=document.createElement('div'); row.className='set-row';
  row.innerHTML=`<div class="set-n">${n}</div>
    <input class="set-field" type="text" value="${reps}" placeholder="—">
    <input class="set-field" type="number" value="${kg||''}" placeholder="${kg?kg:'—'}" min="0" step=".5" onchange="checkPB(this)">
    <button class="set-chk" onclick="doneSet(this)">○</button>`;
  tb.appendChild(row);
}

function doneSet(btn){ btn.classList.toggle('on'); btn.textContent=btn.classList.contains('on')?'✓':'○'; startRest(); }

function checkPB(inp){
  const name=inp.closest('.ex-card2')?.querySelector('input[placeholder="Exercice..."]')?.value;
  const kg=parseFloat(inp.value);
  if(name&&kg>0&&(!pbs[name]||kg>pbs[name])){ pbs[name]=kg; SAVE('pbs',pbs); }
}

