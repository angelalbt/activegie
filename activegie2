function renderSessionList(){
  const phase=getPhase(cycleDay);
  const phDef=PHASES_DEF[curPhaseIdx];

  // Phase meta
  document.getElementById('phase-meta').textContent=phDef.label;

  // Week tabs
  const wt=document.getElementById('week-tabs'); wt.innerHTML='';
  for(let w=0;w<phDef.weeks;w++){
    const btn=document.createElement('button'); btn.className='week-tab'+(w===curWeek?' active':'');
    btn.textContent='Semaine '+(w+1); btn.onclick=(()=>{const ww=w;return()=>selWeek(ww)})();
    wt.appendChild(btn);
  }

  // Build sessions for this week based on freq
  const sessionsThisWeek = getSessForWeek(curPhaseIdx, curWeek);

  const list=document.getElementById('session-list'); list.innerHTML='';
  sessionsThisWeek.forEach((sess,i)=>{
    const done=isSessionDone(curPhaseIdx,curWeek,i);
    const isNext=!done && !sessionsThisWeek.slice(0,i).some((_,ii)=>!isSessionDone(curPhaseIdx,curWeek,ii));
    list.innerHTML+=`<div class="session-card${isNext?' active-prog':''}" onclick="launchSession('${sess.id}',${curPhaseIdx},${curWeek},${i})">
      <div class="session-thumb ${sess.thumbClass}" style="font-size:38px">${sess.emoji}</div>
      <div class="session-body">
        <div class="session-tag">${sess.tag}</div>
        <div class="session-name">${sess.name}</div>
        <div class="session-meta">${sess.meta}</div>
        <div style="margin-top:5px;font-size:10px;font-weight:700;color:${phase.intensityColor}">${phase.intensity}</div>
      </div>
      <div class="session-radio ${done?'done':''}">${done?'✓':''}</div>
    </div>`;
  });

  // CTA — toujours le programme, cycle syncing = adaptation d'intensité uniquement
  const cta=document.getElementById('cta-btn');
  cta.textContent='Commencer le programme !';
  cta.className='btn btn-rose btn-full';
  cta.onclick=startNextSession;
}

function getSessForWeek(phaseIdx, weekIdx){
  // Toujours 3 muscu + 1 run (le cycle syncing adapte l'intensité, pas le programme)
  return [SESSIONS[0], SESSIONS[1], SESSIONS[2], SESSIONS[3]];
}

function isSessionDone(phaseIdx,weekIdx,sessIdx){
  const key=`p${phaseIdx}w${weekIdx}s${sessIdx}`;
  return DB('done_'+key)||false;
}

function markSessionDone(phaseIdx,weekIdx,sessIdx){
  const key=`p${phaseIdx}w${weekIdx}s${sessIdx}`;
  SAVE('done_'+key,true);
}

function selPhase(idx,btn){
  curPhaseIdx=idx; curWeek=0;
  document.querySelectorAll('.phase-tab').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderSessionList();
}

function selWeek(w){
  curWeek=w;
  document.querySelectorAll('.week-tab').forEach((b,i)=>b.classList.toggle('active',i===w));
  renderSessionList();
