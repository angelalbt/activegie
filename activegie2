  const mins  = parseFloat(document.getElementById('lib-dur').value)  || 0;
  const kcal  = parseFloat(document.getElementById('lib-kcal').value) || 0;
  const notes = document.getElementById('lib-notes').value.trim();
  if(!mins){ alert('Entre au moins la durée !'); return; }
  const w = {
    id:Date.now(), date:new Date().toISOString(),
    type:'libre', name, category:libType,
    duration:mins*60, kcal, notes, feel:libFeel
  };
  workouts.unshift(w); SAVE('workouts',workouts);
  resetWorkoutView();
  const feelEmoji = ['😓','😐','💪','🔥'][libFeel-1];
  document.getElementById('c-emoji').textContent = feelEmoji;
  document.getElementById('c-dur').textContent   = mins+' min';
  document.getElementById('c-sets').textContent  = libType;
  document.getElementById('c-vol').textContent   = notes ? notes.slice(0,20)+(notes.length>20?'…':'') : '—';
  const kcalWrap = document.getElementById('c-kcal-wrap');
  if(kcal){ document.getElementById('c-kcal').textContent=kcal; kcalWrap.style.display='block'; }
  else { kcalWrap.style.display='none'; }
  document.getElementById('c-sub').textContent = name+' enregistrée ✓';
  document.getElementById('complete').classList.add('on');
}

// ── MOOD ──────────────────────────────────────────────────────
const MOOD_LABELS = ['','Épuisée','Pas top','Neutre','Bien','Super','Au top'];
const MOOD_EMOJIS = ['','😴','😔','😐','🙂','😊','🤩'];
let curMood = 0;

function selMood(v, btn){
  curMood = v;
  document.querySelectorAll('#mood-btns .mood-btn').forEach(b => b.classList.remove('sel'));
  btn.classList.add('sel');
}

function saveMood(){
  if(!curMood){ alert('Sélectionne un mood !'); return; }
  const moods = DB('moods') || [];
  moods.unshift({
    date: new Date().toISOString(),
    mood: curMood,
    note: document.getElementById('mood-note').value.trim()
  });
  SAVE('moods', moods.slice(0, 30)); // keep last 30
  document.getElementById('mood-note').value = '';
  document.querySelectorAll('#mood-btns .mood-btn').forEach(b => b.classList.remove('sel'));
  curMood = 0;
  renderMoodHistory();
}

function renderMoodHistory(){
  const moods = DB('moods') || [];
  const wrap = document.getElementById('mood-history');
  if(!moods.length){ wrap.style.display='none'; return; }
  wrap.style.display = 'flex';
  wrap.innerHTML = moods.slice(0,5).map(m => `
    <div class="mood-entry">
      <div class="mood-entry-emoji">${MOOD_EMOJIS[m.mood]}</div>
      <div class="mood-entry-text">${MOOD_LABELS[m.mood]}${m.note ? ' — '+m.note.slice(0,40)+(m.note.length>40?'…':'') : ''}</div>
      <div class="mood-entry-date">${fmtDate(m.date)}</div>
    </div>`).join('');
}

// ── BIEN-ÊTRE ─────────────────────────────────────────────────
function renderBienetre(){ updateCycleUI(); renderMoodHistory(); }
function openYogaLog(type,card){
  yogaType=type;
  document.querySelectorAll('.yoga-card').forEach(c=>c.classList.remove('sel'));
  card.classList.add('sel');
  const area=document.getElementById('yoga-log-area'); area.style.display='block';
  document.getElementById('yoga-log-title').textContent=type;
}
function setYogaFeel(v,btn){ yogaFeel=v; document.querySelectorAll('#yoga-feel-row .feel-btn2').forEach(b=>b.classList.remove('sel')); btn.classList.add('sel'); }
function saveYoga(){
  const mins=parseFloat(document.getElementById('yi-time').value);
  if(!mins){alert('Entre la durée !');return;}
  const w={id:Date.now(),date:new Date().toISOString(),type:'yoga',name:yogaType,duration:mins*60,feel:yogaFeel};
  workouts.unshift(w); SAVE('workouts',workouts);
  document.getElementById('yi-time').value='';
  document.getElementById('yoga-log-area').style.display='none';
