<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<meta name="theme-color" content="#F5F2EE">
<title>Elevate · Training</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#F5F2EE; --white:#FFFFFF; --text:#1A1A1A; --muted:#9A9090;
  --border:#EAE6E2; --rose:#C8758A; --rose-bg:#F8ECEF; --rose2:#E09AAC;
  --dark:#1C1818; --dark2:#2A2424; --green:#22A878; --purple:#8B6FBB;
  --r:16px; --r2:24px; --safe:env(safe-area-inset-bottom,0px); --sans:'Inter',system-ui,sans-serif;
}
html,body{height:100%;overflow:hidden;background:var(--bg)}
body{font-family:var(--sans);color:var(--text);font-size:15px;-webkit-font-smoothing:antialiased;overscroll-behavior:none}

/* Layout */
#app{display:flex;flex-direction:column;height:100vh;height:100dvh}
.view{display:none;flex:1;overflow-y:auto;overflow-x:hidden;padding-bottom:calc(80px + var(--safe));background:var(--bg)}
.view.active{display:block}
.view::-webkit-scrollbar{display:none}

/* Nav */
.nav{position:fixed;bottom:0;left:0;right:0;height:calc(68px + var(--safe));background:rgba(255,255,255,.96);backdrop-filter:blur(20px);border-top:1px solid var(--border);display:flex;align-items:flex-start;padding-top:8px;z-index:100}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;cursor:pointer;color:var(--muted);transition:color .2s;padding-top:2px}
.nav-btn.active{color:var(--rose)}
.nav-btn svg{width:22px;height:22px;stroke-width:1.8}
.nav-label{font-size:9px;font-weight:700;letter-spacing:.04em}

/* Buttons */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;border:none;border-radius:100px;cursor:pointer;font-family:var(--sans);font-weight:700;padding:14px 22px;letter-spacing:.04em;transition:filter .15s,transform .1s;text-transform:uppercase;font-size:13px}
.btn:active{filter:brightness(.88);transform:scale(.97)}
.btn-rose{background:var(--rose);color:#fff}
.btn-dark{background:var(--dark);color:#fff}
.btn-ghost{background:transparent;color:var(--rose);border:1.5px solid var(--rose)}
.btn-green{background:var(--green);color:#fff}
.btn-purple{background:var(--purple);color:#fff}
.btn-full{width:100%;padding:17px;border-radius:100px;font-size:14px;letter-spacing:.08em}
.btn-claude{background:linear-gradient(135deg,#7c3aed,#a855f7);color:#fff}

/* Section headers (collapsible) */
.sec-hdr{display:flex;justify-content:space-between;align-items:center;padding:20px 20px 14px;cursor:pointer}
.sec-hdr-title{font-size:14px;font-weight:900;letter-spacing:.12em;text-transform:uppercase}
.sec-hdr-arrow{width:28px;height:28px;border-radius:50%;background:var(--dark);display:flex;align-items:center;justify-content:center;color:#fff;font-size:13px;transition:transform .25s}
.sec-hdr-arrow.open{transform:rotate(180deg)}
.sec-body{overflow:hidden;transition:max-height .3s ease}

/* Pill selector */
.pill-row{display:flex;gap:8px;padding:0 20px 14px}
.pill-sel{padding:9px 18px;border-radius:100px;border:1.5px solid var(--border);background:transparent;color:var(--muted);font-family:var(--sans);font-size:14px;font-weight:600;cursor:pointer;transition:all .2s}
.pill-sel.active{background:var(--rose);border-color:var(--rose);color:#fff}
.prefs-label{padding:0 20px 8px;font-size:12px;color:var(--muted);font-weight:600;letter-spacing:.06em;text-transform:uppercase}

/* Cycle mini-card in prefs */
.cycle-pref{margin:0 20px 16px;padding:14px 16px;background:var(--white);border:1px solid var(--border);border-radius:var(--r);display:flex;justify-content:space-between;align-items:center}
.cycle-pref-left{}
.cycle-pref-phase{font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase}
.cycle-pref-name{font-size:16px;font-weight:900;margin-top:1px}
.cycle-pref-advice{font-size:11px;color:var(--muted);margin-top:2px;max-width:200px;line-height:1.4}
.cycle-ctrl{display:flex;flex-direction:column;align-items:center;gap:3px}
.cycle-ctrl-val{font-size:22px;font-weight:900}
.cycle-ctrl-btns{display:flex;gap:4px}
.cyc-btn{width:26px;height:26px;border-radius:8px;background:var(--bg);border:1px solid var(--border);font-size:15px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text)}

/* Phase tabs */
.phase-tabs{display:flex;align-items:center;gap:0;padding:0 20px 10px}
.phase-tab{background:none;border:none;font-family:var(--sans);font-size:15px;font-weight:700;color:var(--muted);cursor:pointer;padding:4px 0;position:relative}
.phase-tab.active{color:var(--rose)}
.phase-tab.active::after{content:'';position:absolute;bottom:-4px;left:0;right:0;height:2px;background:var(--rose);border-radius:2px}
.phase-sep{color:var(--border);margin:0 12px;font-size:18px;user-select:none}
.phase-meta{padding:0 20px 14px;font-size:13px;color:var(--muted);font-weight:500}

/* Session cards */
.session-card{display:flex;align-items:center;margin:0 20px 10px;background:var(--white);border-radius:var(--r);overflow:hidden;border:1px solid var(--border);cursor:pointer;transition:box-shadow .2s}
.session-card:active{box-shadow:0 2px 12px rgba(200,117,138,.2)}
.session-thumb{width:100px;height:80px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:28px;position:relative;overflow:hidden}
.session-body{flex:1;padding:12px 14px}
.session-tag{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--rose);margin-bottom:2px}
.session-name{font-size:15px;font-weight:800;letter-spacing:-.01em;margin-bottom:2px}
.session-meta{font-size:11px;color:var(--muted)}
.session-radio{width:24px;height:24px;border-radius:50%;border:1.5px solid var(--border);flex-shrink:0;margin-right:14px;display:flex;align-items:center;justify-content:center;transition:all .2s}
.session-radio.done{background:var(--rose);border-color:var(--rose);color:#fff;font-size:11px}
.session-card.active-prog .session-radio{border-color:var(--rose);border-width:2px}

/* Thumbs — pastels clairs avec emoji centré */
.th-glutes{background:#fdf0f4}
.th-core  {background:#f0f3fd}
.th-run-s {background:#f0fdf6}
.th-run   {background:#f0fdf9}
.th-yoga  {background:#f5f0ff}
.thumb-figure{font-size:38px;line-height:1}

/* Week tabs */
.week-tabs{display:flex;gap:0;padding:0 20px;overflow-x:auto;border-bottom:1px solid var(--border);margin-bottom:12px}
.week-tabs::-webkit-scrollbar{display:none}
.week-tab{flex-shrink:0;padding:10px 14px;background:none;border:none;border-bottom:2px solid transparent;font-family:var(--sans);font-size:13px;font-weight:600;color:var(--muted);cursor:pointer;transition:all .2s;margin-bottom:-1px}
.week-tab.active{color:var(--text);border-bottom-color:var(--text)}

/* CTA area */
.cta-area{padding:16px 20px 0;display:flex;gap:10px;align-items:center}
.fav-btn{width:50px;height:50px;border-radius:50%;background:var(--dark);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}

/* Workout view */
.wk-hdr{padding:52px 20px 8px;background:var(--white);border-bottom:1px solid var(--border)}
.wk-hdr-tag{font-size:11px;color:var(--rose);font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px}
.wk-hdr-title{font-size:22px;font-weight:900;letter-spacing:-.02em}
.wk-hdr-meta{font-size:13px;color:var(--muted);margin-top:2px;display:flex;align-items:center;gap:8px}
.timer-badge{font-size:14px;font-weight:800;color:var(--rose)}
.ex-card2{margin:10px 20px 0;background:var(--white);border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.ex-hdr2{display:flex;justify-content:space-between;align-items:flex-start;padding:14px 16px 8px}
.ex-num{width:24px;height:24px;border-radius:8px;background:var(--rose-bg);color:var(--rose);font-size:11px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.ex-info{flex:1;padding:0 12px}
.ex-name2{font-size:15px;font-weight:800}
.ex-tip2{font-size:11px;color:var(--muted);margin-top:2px;line-height:1.4}
.ex-del{width:28px;height:28px;border-radius:8px;background:var(--bg);border:1px solid var(--border);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:16px}
.sets-area{padding:0 16px 12px}
.set-row{display:grid;grid-template-columns:30px 1fr 1fr 36px;gap:8px;align-items:center;padding:7px 0;border-top:1px solid var(--border)}
.set-n{font-size:12px;font-weight:700;color:var(--muted);text-align:center}
.set-field{background:var(--bg);border:1.5px solid var(--border);border-radius:10px;color:var(--text);font-family:var(--sans);font-size:14px;font-weight:700;text-align:center;padding:8px 6px;outline:none;width:100%}
.set-field:focus{border-color:var(--rose)}
.set-chk{width:30px;height:30px;border-radius:50%;border:1.5px solid var(--border);background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:14px;transition:all .2s}
.set-chk.on{background:var(--green);border-color:var(--green);color:#fff}
.add-set2{width:100%;padding:10px;background:none;border:none;color:var(--rose);font-family:var(--sans);font-size:13px;font-weight:600;cursor:pointer;text-align:center;border-top:1px solid var(--border)}
.wk-actions{padding:16px 20px 0;display:flex;gap:10px}

/* Bien-être view */
.be-cycle{margin:16px 20px 0;border-radius:var(--r2);padding:20px;overflow:hidden;position:relative}
.be-cycle-tag{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px}
.be-cycle-name{font-size:24px;font-weight:900;letter-spacing:-.03em;margin-bottom:4px}
.be-cycle-advice{font-size:13px;opacity:.8;line-height:1.5;margin-bottom:16px}
.be-cycle-days{display:flex;gap:2px;margin-bottom:16px}
.be-day-dot{width:9px;height:9px;border-radius:50%;background:rgba(255,255,255,.25);transition:all .2s}
.be-day-dot.past{background:rgba(255,255,255,.8)}
.be-day-dot.cur{background:#fff;transform:scale(1.4)}
.be-ctrl{display:flex;align-items:center;gap:12px}
.be-day-num{font-size:28px;font-weight:900}
.be-ctrl-btns{display:flex;gap:6px}
.be-cyc-btn{width:32px;height:32px;border-radius:10px;background:rgba(255,255,255,.2);border:none;color:#fff;font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center}

/* Mood card */
.mood-card{margin:12px 20px 0;background:var(--white);border:1px solid var(--border);border-radius:var(--r2);padding:18px 20px}
.mood-card-title{font-size:16px;font-weight:900;letter-spacing:-.01em;margin-bottom:4px}
.mood-card-sub{font-size:12px;color:var(--muted);margin-bottom:14px}
.mood-emojis{display:flex;gap:8px;margin-bottom:14px}
.mood-btn{flex:1;padding:10px 4px;border-radius:12px;border:1.5px solid var(--border);background:transparent;font-size:22px;cursor:pointer;transition:all .2s;text-align:center}
.mood-btn.sel{border-color:var(--rose);background:var(--rose-bg);transform:scale(1.1)}
.mood-note{width:100%;background:var(--bg);border:1.5px solid var(--border);border-radius:12px;font-family:var(--sans);font-size:13px;color:var(--text);padding:11px 14px;outline:none;resize:none;min-height:70px;line-height:1.5;margin-bottom:12px}
.mood-note:focus{border-color:var(--rose)}
.mood-note::placeholder{color:var(--muted)}
.mood-history{margin-top:14px;border-top:1px solid var(--border);padding-top:12px;display:flex;flex-direction:column;gap:8px}
.mood-entry{display:flex;align-items:center;gap:10px}
.mood-entry-emoji{font-size:20px}
.mood-entry-text{flex:1;font-size:13px;color:var(--muted)}
.mood-entry-date{font-size:11px;color:var(--muted)}

/* Yoga cards */
.yoga-card{margin:10px 20px 0;background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:16px;display:flex;gap:14px;align-items:center;cursor:pointer;transition:border-color .2s}
.yoga-card:active,.yoga-card.sel{border-color:var(--purple);background:rgba(139,111,187,.04)}
.yoga-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
.yoga-body{flex:1}
.yoga-name{font-size:15px;font-weight:800;margin-bottom:2px}
.yoga-meta{font-size:12px;color:var(--muted)}
.yoga-arrow{color:var(--muted);font-size:18px}

/* Run log */
.run-big-inp{width:100%;background:var(--white);border:1.5px solid var(--border);border-radius:14px;color:var(--text);font-family:var(--sans);font-size:28px;font-weight:800;text-align:center;padding:16px;outline:none}
.run-big-inp:focus{border-color:var(--green)}
.run-stats-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:0 20px 12px}
.run-stat2{background:var(--white);border:1px solid var(--border);border-radius:14px;padding:14px}
.run-stat2-v{font-size:22px;font-weight:900;letter-spacing:-.02em}
.run-stat2-l{font-size:11px;color:var(--muted);margin-top:2px}
.feel-row2{display:flex;gap:8px;padding:0 20px 14px}
.feel-btn2{flex:1;padding:13px;background:var(--white);border:1.5px solid var(--border);border-radius:12px;font-size:22px;cursor:pointer;transition:border-color .2s}
.feel-btn2.sel{border-color:var(--green);background:rgba(34,168,120,.05)}

/* Nutrition */
.nutr-hero{margin:12px 20px 0;border-radius:var(--r2);height:200px;position:relative;overflow:hidden;background:linear-gradient(135deg,#2d1b1b,#1a1012);display:flex;flex-direction:column;justify-content:flex-end}
.nutr-hero-emoji{position:absolute;top:50%;left:50%;transform:translate(-50%,-65%);font-size:64px}
.nutr-hero-body{padding:16px 18px;background:linear-gradient(to top,rgba(0,0,0,.7),transparent)}
.nutr-hero-tag{font-size:10px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.6);margin-bottom:4px}
.nutr-hero-title{font-size:20px;font-weight:900;color:#fff;letter-spacing:-.02em}
.nutr-hero-meta{font-size:12px;color:rgba(255,255,255,.5);margin-top:2px}
.meal-plan-wrap{margin:12px 20px 0;background:var(--white);border:1px solid var(--border);border-radius:var(--r);overflow:hidden}
.meal-day2{border-bottom:1px solid var(--border)}
.meal-day2:last-child{border-bottom:none}
.meal-day2-hdr{padding:12px 16px;background:var(--bg);display:flex;justify-content:space-between;align-items:center;cursor:pointer}
.meal-day2-name{font-size:12px;font-weight:800;letter-spacing:.08em;text-transform:uppercase}
.meal-day2-cal{font-size:11px;color:var(--muted)}
.meal-slot2{padding:10px 16px;border-top:1px solid var(--border);display:flex;gap:12px;align-items:center}
.meal-slot2-icon{font-size:22px}
.meal-slot2-body{flex:1}
.meal-slot2-time{font-size:10px;color:var(--muted);font-weight:700;letter-spacing:.06em;text-transform:uppercase;margin-bottom:1px}
.meal-slot2-name{font-size:14px;font-weight:700}
.meal-slot2-cal{font-size:11px;color:var(--muted);margin-top:1px}
.gen-card2{margin:12px 20px 0;background:linear-gradient(135deg,#1e1228,#120d1a);border-radius:var(--r);padding:20px}
.gen-card2-title{font-size:16px;font-weight:800;color:#fff;margin-bottom:4px}
.gen-card2-sub{font-size:12px;color:rgba(255,255,255,.5);margin-bottom:14px}
.api-inp{width:100%;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:10px;color:#fff;font-family:var(--sans);font-size:13px;padding:11px 14px;outline:none;margin-bottom:8px}
.api-inp:focus{border-color:#a855f7}
.api-inp::placeholder{color:rgba(255,255,255,.3)}
.gen-prefs2{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}
.gen-pref2{padding:7px 12px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:100px;font-size:12px;font-weight:600;color:rgba(255,255,255,.7);cursor:pointer;transition:all .2s}
.gen-pref2.sel{background:rgba(168,85,247,.3);border-color:#a855f7;color:#e9d5ff}
.claude-loading2{display:none;text-align:center;padding:14px;color:rgba(255,255,255,.5);font-size:13px}
.claude-loading2.show{display:block}

/* Stats */
.stat-card{margin:0 20px 10px;background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:16px}
.stat-card-title{font-size:13px;font-weight:800;margin-bottom:2px}
.stat-card-sub{font-size:11px;color:var(--muted);margin-bottom:14px}
.bars2{display:flex;align-items:flex-end;gap:6px;height:80px}
.bar2-w{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.bar2{width:100%;border-radius:5px 5px 0 0;min-height:3px}
.bar2.rose{background:linear-gradient(to top,var(--rose),var(--rose2))}
.bar2.grn{background:linear-gradient(to top,var(--green),#6ee7b7)}
.bar2-l{font-size:9px;color:var(--muted)}
.pb-row2{display:flex;gap:8px;overflow-x:auto;padding:4px 20px 4px}
.pb-row2::-webkit-scrollbar{display:none}
.pb-item2{flex-shrink:0;background:var(--white);border:1px solid var(--border);border-radius:14px;padding:14px 16px;min-width:120px}
.pb-val2{font-size:22px;font-weight:900}
.pb-ex2{font-size:11px;color:var(--muted);margin-top:2px}
.pb-badge2{display:inline-block;font-size:9px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;background:var(--rose-bg);color:var(--rose);border-radius:5px;padding:2px 6px;margin-top:4px}

/* History */
.hist2{margin:0 20px 8px;background:var(--white);border:1px solid var(--border);border-radius:14px;padding:14px 16px;display:flex;gap:12px;align-items:center}
.hist2-thumb{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.hist2-body{flex:1}
.hist2-type{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:2px}
.hist2-name{font-size:14px;font-weight:800}
.hist2-meta{font-size:11px;color:var(--muted);margin-top:1px}
.hist2-r{text-align:right;flex-shrink:0}
.hist2-date{font-size:10px;color:var(--muted)}
.hist2-val{font-size:16px;font-weight:900;margin-top:3px}

/* Pills stats row */
.stats-pills{display:flex;gap:10px;padding:0 20px 16px;overflow-x:auto}
.stats-pills::-webkit-scrollbar{display:none}
.stats-pill{flex-shrink:0;background:var(--white);border:1px solid var(--border);border-radius:14px;padding:12px 16px;text-align:center;min-width:90px}
.stats-pill-v{font-size:24px;font-weight:900;letter-spacing:-.03em}
.stats-pill-l{font-size:10px;color:var(--muted);margin-top:2px}

/* Complete overlay */
.complete{position:fixed;inset:0;background:#fff;z-index:300;display:none;flex-direction:column;align-items:center;justify-content:center;padding:40px 24px;text-align:center}
.complete.on{display:flex}
.c-emoji{font-size:64px;margin-bottom:20px}
.c-title{font-size:30px;font-weight:900;letter-spacing:-.03em;margin-bottom:8px}
.c-sub{font-size:15px;color:var(--muted);margin-bottom:32px}
.c-stats{display:flex;gap:24px;margin-bottom:40px}
.c-stat-v{font-size:26px;font-weight:900;color:var(--rose)}
.c-stat-l{font-size:12px;color:var(--muted);margin-top:2px}

/* Rest overlay pill */
.rest-bar{position:fixed;top:0;left:0;right:0;background:rgba(255,255,255,.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:10px 20px;display:none;justify-content:space-between;align-items:center;z-index:50}
.rest-bar.on{display:flex}
.rest-timer{font-size:20px;font-weight:900;font-variant-numeric:tabular-nums;color:var(--rose)}
.rest-label{font-size:11px;color:var(--muted)}

/* Section page header */
.page-hdr{padding:52px 20px 10px}
.page-hdr-sub{font-size:12px;color:var(--muted);margin-bottom:3px}
.page-hdr-title{font-size:26px;font-weight:900;letter-spacing:-.03em}

/* Divider */
.divider{height:1px;background:var(--border);margin:4px 20px}
.spacer{height:8px}
</style>
</head>
<body>
<div id="app">

<!-- ══ ACCUEIL — Programme ══ -->
<div class="view active" id="view-accueil">

  <!-- Préférences -->
  <div class="sec-hdr" onclick="toggle('prefs-body','prefs-arrow')">
    <span class="sec-hdr-title">Préférences</span>
    <div class="sec-hdr-arrow open" id="prefs-arrow">↑</div>
  </div>
  <div class="sec-body" id="prefs-body">
