  document.getElementById('c-sub').textContent='Séance douce enregistrée 🧘';
  document.getElementById('complete').classList.add('on');
}

// ── NUTRITION ─────────────────────────────────────────────────
function renderNutrition(){
  const key=DB('apiKey'); if(key) document.getElementById('api-key').value=key;
  if(mealPlan) renderMealPlan(mealPlan);
}
function saveKey(){SAVE('apiKey',document.getElementById('api-key').value);}
function selKcal(v,btn){ targetKcal=v; SAVE('kcal',v); document.querySelectorAll('#kcal-row .gen-pref2').forEach(b=>b.classList.remove('sel')); btn.classList.add('sel'); }

async function generateMealPlan(){
  const key=document.getElementById('api-key').value.trim();
  if(!key){alert('Entre ta clé API Anthropic (sk-ant-...)');return;}
  SAVE('apiKey',key);
  document.getElementById('claude-loading').classList.add('show');
  document.querySelector('.btn-claude').disabled=true;
  const prefs=Array.from(document.querySelectorAll('.gen-pref2.sel')).map(b=>b.textContent.trim()).join(', ')||'Aucune';
  const phase=getPhase(cycleDay);
  const CYCLE_FOOD = {
    'Hiver · Fatigomax':     'Menstruelle J1-3 : plats CHAUDS et mijotés. Priorité FER (lentilles, épinards, légumineuses), MAGNÉSIUM, OMÉGA-3. Rien de cru ou difficile à digérer. Pas de sucre raffiné. Réconfort avant tout.',
    'Printemps · Folliculaire':'Folliculaire J4-12 : repas colorés, variés, cru OK. Protéines et fibres. Bowls, salades composées. Bonne fenêtre pour essayer de nouvelles recettes.',
    'Été · Ovulatoire':      'Ovulatoire J13-15 : léger, anti-inflammatoire, peu cuit ou cru. Antioxydants : myrtilles, épinards, avocat. Repas rapides.',
    'Automne · Lutéale':     'Lutéale J16-28 : CHAUD et réconfortant. Glycémie stable — exit sucre raffiné. MAGNÉSIUM prioritaire : chocolat noir 70%, graines de courge, oléagineux, légumes verts. Dîners légers et digestes.',
  };
  const foodGuide = CYCLE_FOOD[phase.name] || '';
  const prompt=`Tu es nutritionniste experte en cycle syncing et sport féminin. Plan alimentaire 7 jours pour une femme, 3 séances renforcement fonctionnel + 1 running/semaine. Objectif : longévité, prendre en muscle plutôt qu'en gras.

PHASE ACTUELLE : ${phase.name} (J${cycleDay}/28)
DIRECTIVE PHASE : ${foodGuide}
RÈGLES TOUTES PHASES : protéines à chaque repas, glucides complexes avant séances intenses, protéines dans les 30 min après séance.
Objectif calorique : ${targetKcal} kcal/jour. Préférences : ${prefs}.

La "phase_note" = conseil pratique concret lié à la phase (aliment, timing, astuce récupération).

JSON UNIQUEMENT :
{"days":[{"day":"Lundi","calories":1850,"phase_note":"Astuce cycle concrète","meals":[{"time":"Petit-déjeuner","emoji":"🥣","name":"Porridge banane-cannelle","calories":380},{"time":"Déjeuner","emoji":"🥗","name":"Bowl lentilles épinards","calories":520},{"time":"Collation","emoji":"🍫","name":"Chocolat noir amandes","calories":180},{"time":"Dîner","emoji":"🍲","name":"Mijoté poulet patate douce","calories":650}]}]}
7 jours Lundi→Dimanche. Sois variée et précise.`;
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json','x-api-key':key,'anthropic-version':'2023-06-01','anthropic-dangerous-direct-browser-access':'true'},body:JSON.stringify({model:'claude-haiku-4-5-20251001',max_tokens:2500,messages:[{role:'user',content:prompt}]})});
    if(!res.ok){const e=await res.json();throw new Error(e.error?.message||'Erreur API');}
    const data=await res.json();
    const json=JSON.parse(data.content[0].text.match(/\{[\s\S]*\}/)[0]);
    mealPlan=json; SAVE('mealPlan',json); renderMealPlan(json);
  }catch(e){alert('Erreur : '+e.message);}
  finally{document.getElementById('claude-loading').classList.remove('show');document.querySelector('.btn-claude').disabled=false;}
}

function renderMealPlan(plan){
  if(!plan?.days)return;
  const today=plan.days[(new Date().getDay()+6)%7]||plan.days[0];
  const lunch=today?.meals?.find(m=>m.time==='Déjeuner')||today?.meals?.[0];
  if(lunch){
    document.getElementById('hero-emoji').textContent=lunch.emoji||'🍽️';
    document.getElementById('hero-meal').textContent=lunch.name;
    document.getElementById('hero-meta').textContent=today.day+' · '+today.calories+' kcal';
  }
  document.getElementById('meal-plan-card').innerHTML=plan.days.map(day=>`
    <div class="meal-day2">
      <div class="meal-day2-hdr">
        <div><div class="meal-day2-name">${day.day}</div>${day.phase_note?`<div style="font-size:10px;color:var(--muted);margin-top:1px">💡 ${day.phase_note}</div>`:''}</div>
        <div class="meal-day2-cal">${day.calories} kcal</div>
      </div>
      ${day.meals.map(m=>`<div class="meal-slot2"><div class="meal-slot2-icon">${m.emoji}</div><div class="meal-slot2-body"><div class="meal-slot2-time">${m.time}</div><div class="meal-slot2-name">${m.name}</div><div class="meal-slot2-cal">${m.calories} kcal</div></div></div>`).join('')}
    </div>`).join('');
}

// ── PROFIL ────────────────────────────────────────────────────
function renderProfil(){
  let streak=0; const d=new Date(); d.setHours(0,0,0,0);
  const dc=new Date(d);
  while(workouts.find(w=>new Date(w.date).toDateString()===dc.toDateString())){streak++;dc.setDate(dc.getDate()-1);}
  const km    = workouts.filter(w=>w.type==='run').reduce((s,w)=>s+(w.distance||0),0);
  const kcalTotal = workouts.reduce((s,w)=>s+(w.kcal||0),0);
  document.getElementById('stats-pills').innerHTML=`
    <div class="stats-pill"><div class="stats-pill-v">${streak}</div><div class="stats-pill-l">🔥 Streak</div></div>
    <div class="stats-pill"><div class="stats-pill-v">${workouts.length}</div><div class="stats-pill-l">💪 Séances</div></div>
    <div class="stats-pill"><div class="stats-pill-v">${Math.round(km*10)/10}</div><div class="stats-pill-l">🏃 km</div></div>
    <div class="stats-pill"><div class="stats-pill-v">${workouts.filter(w=>w.type==='yoga').length}</div><div class="stats-pill-l">🧘 Yoga</div></div>
    ${kcalTotal>0?`<div class="stats-pill"><div class="stats-pill-v" style="color:var(--orange)">${Math.round(kcalTotal).toLocaleString('fr')}</div><div class="stats-pill-l">🔥 kcal totales</div></div>`:''}`;

  const pbr=document.getElementById('pb-row'); pbr.innerHTML='';
  if(!Object.keys(pbs).length) pbr.innerHTML='<div style="padding:4px 0;color:var(--muted);font-size:13px">Lance ta première séance 🏆</div>';
  else Object.entries(pbs).slice(0,6).forEach(([ex,kg])=>{
    pbr.innerHTML+=`<div class="pb-item2"><div class="pb-val2">${kg}<span style="font-size:13px;color:var(--muted)"> kg</span></div><div class="pb-ex2">${ex}</div><div class="pb-badge2">PR</div></div>`;
  });

  const wData=workouts.filter(w=>w.type==='weights').slice(0,8).reverse();
  const bw=document.getElementById('bar-w'); bw.innerHTML='';
  if(wData.length){const mx=Math.max(...wData.map(w=>w.reps||1));wData.forEach(w=>{const p=Math.round((w.reps||0)/mx*100)||5;bw.innerHTML+=`<div class="bar2-w"><div class="bar2 rose" style="height:${p}%"></div><div class="bar2-l">${new Date(w.date).getDate()}/${new Date(w.date).getMonth()+1}</div></div>`;});}
  else bw.innerHTML='<div style="color:var(--muted);font-size:12px;align-self:center">Aucune séance</div>';

  const rData=workouts.filter(w=>w.type==='run').slice(0,8).reverse();
  const br=document.getElementById('bar-r'); br.innerHTML='';
  if(rData.length){const mx=Math.max(...rData.map(w=>w.distance||1));rData.forEach(w=>{const p=Math.round(w.distance/mx*100)||5;br.innerHTML+=`<div class="bar2-w"><div class="bar2 grn" style="height:${p}%"></div><div class="bar2-l">${w.distance}km</div></div>`;});}
  else br.innerHTML='<div style="color:var(--muted);font-size:12px;align-self:center">Aucune sortie</div>';

  // Progression des charges — tous les exercices loggés au moins 2 fois
  const cl=document.getElementById('charges-list'); cl.innerHTML='';
  const exNames=[...new Set(workouts.filter(w=>w.exercises).flatMap(w=>w.exercises.map(e=>e.name)))];
  const exWithHistory=exNames.map(n=>({name:n,history:getChargeHistory(n)})).filter(e=>e.history.length>=1).sort((a,b)=>b.history[b.history.length-1].kg-a.history[a.history.length-1].kg);
  if(!exWithHistory.length){ cl.innerHTML='<div style="color:var(--muted);font-size:13px;padding-bottom:8px">Lance ta première séance pour voir tes progressions 📈</div>'; }
  else exWithHistory.forEach(({name,history})=>{
    const last=history[history.length-1].kg;
    const prev=history.length>1?history[history.length-2].kg:null;
    const delta=prev!==null?last-prev:null;
    const arrow=delta===null?'':delta>0?`<span style="color:var(--green);font-weight:700">↑ +${delta}kg</span>`:delta<0?`<span style="color:var(--rose)">↓ ${delta}kg</span>`:`<span style="color:var(--muted)">→</span>`;
    const dots=history.slice(-6).map((h,i,arr)=>{
      const maxKg=Math.max(...arr.map(x=>x.kg));
      const pct=Math.round(h.kg/maxKg*100);
      return `<div style="display:flex;flex-direction:column;align-items:center;gap:3px;flex:1">
        <div style="width:100%;border-radius:3px 3px 0 0;background:var(--rose);opacity:${0.4+pct/100*0.6};height:${Math.max(pct*0.3,4)}px"></div>
        <div style="font-size:9px;color:var(--muted)">${h.kg}</div>
      </div>`;
    }).join('');
    cl.innerHTML+=`<div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:12px 14px;margin-bottom:8px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
        <div style="font-size:14px;font-weight:800">${name}</div>
        <div style="display:flex;align-items:center;gap:8px">
          ${arrow}
          <div style="font-size:18px;font-weight:900;color:var(--rose)">${last}<span style="font-size:12px;color:var(--muted);font-weight:400"> kg</span></div>
        </div>
      </div>
      <div style="display:flex;align-items:flex-end;gap:4px;height:34px">${dots}</div>
    </div>`;
  });

  const hl=document.getElementById('hist-list');
  if(!workouts.length){hl.innerHTML='<div style="padding:0 20px;color:var(--muted);font-size:14px">Aucune séance</div>';return;}
  hl.innerHTML=workouts.map(w=>{
    const isLibre = w.type==='libre';
    const icon  = w.type==='run'?'🏃':w.type==='yoga'?'🧘':isLibre?'🎯':'💪';
    const bg    = w.type==='run'?'#f0fdf4':w.type==='yoga'?'#f3eeff':isLibre?'#fff7ed':'#fdf2f5';
    const color = w.type==='run'?'var(--green)':w.type==='yoga'?'var(--purple)':isLibre?'var(--orange)':'var(--rose)';
    const typeLabel = w.type==='run'?'Running':w.type==='yoga'?'Yoga':isLibre?('Libre · '+w.category):'Renforcement';
    const val = w.type==='run'
      ? w.distance+'km'
      : w.type==='yoga'
      ? Math.floor(w.duration/60)+'min'
      : isLibre
      ? (w.kcal ? w.kcal+' kcal' : Math.floor(w.duration/60)+'min')
      : (w.sets||0)+' sets';
    const kcalBadge = (w.kcal&&!isLibre) ? `<span style="font-size:10px;color:var(--orange);font-weight:700;margin-left:6px">🔥${w.kcal} kcal</span>` : '';
    return `<div class="hist2">
      <div class="hist2-thumb" style="background:${bg}">${icon}</div>
      <div class="hist2-body"><div class="hist2-type" style="color:${color}">${typeLabel}</div><div class="hist2-name">${w.name}</div><div class="hist2-meta">${fmt(w.duration)}${kcalBadge}</div></div>
      <div class="hist2-r"><div class="hist2-date">${fmtDate(w.date)}</div><div class="hist2-val" style="color:${color}">${val}</div></div>
    </div>`;
  }).join('');
}

// ── UTILS ─────────────────────────────────────────────────────
function fmt(s){const m=Math.floor(s/60);return `${String(m).padStart(2,'0')}:${String(Math.floor(s%60)).padStart(2,'0')}`;}
function fmtDate(iso){return new Date(iso).toLocaleDateString('fr-FR',{day:'numeric',month:'short'});}

// ── INIT ──────────────────────────────────────────────────────
document.querySelectorAll('.sec-body').forEach(el=>el.style.maxHeight='none');
renderAccueil();
</script>
