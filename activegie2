function calcRun(){
  const dist=parseFloat(document.getElementById('ri-dist')?.value)||0;
  const mins=parseFloat(document.getElementById('ri-time')?.value)||0;
  if(document.getElementById('r-dist')) document.getElementById('r-dist').textContent=dist||0;
  if(dist>0&&mins>0){
    const p=mins/dist,pm=Math.floor(p),ps=Math.round((p-pm)*60);
    if(document.getElementById('r-pace')) document.getElementById('r-pace').textContent=`${pm}'${String(ps).padStart(2,'0')}"`;
  } else { if(document.getElementById('r-pace')) document.getElementById('r-pace').textContent='—'; }
}

function setRunFeel(v,btn){ runFeel=v; document.querySelectorAll('.feel-row2 .feel-btn2').forEach(b=>b.classList.remove('sel')); btn.classList.add('sel'); }

function saveRun(){
  const dist=parseFloat(document.getElementById('ri-dist')?.value);
  const mins=parseFloat(document.getElementById('ri-time')?.value);
  if(!dist||!mins){alert('Entre distance et durée !');return;}
  const p=mins/dist,pm=Math.floor(p),ps=Math.round((p-pm)*60);
  const w={id:Date.now(),date:new Date().toISOString(),type:'run',name:`${dist} km`,distance:dist,duration:mins*60,pace:`${pm}'${String(ps).padStart(2,'0')}"`,kcal:Math.round(dist*60),feel:runFeel};
  workouts.unshift(w); SAVE('workouts',workouts);
  if(activeProgKey) { markSessionDone(activeProgKey.phaseIdx,activeProgKey.weekIdx,activeProgKey.sessIdx); activeProgKey=null; }
  document.getElementById('c-emoji').textContent=['😓','😐','😊','🔥'][runFeel-1];
  document.getElementById('c-dur').textContent=mins+' min';
  document.getElementById('c-sets').textContent=dist+' km';
  document.getElementById('c-vol').textContent=w.pace+'/km';
  document.getElementById('c-sub').textContent=['Dur mais fait !','Bonne sortie !','Super run !','En feu !'][runFeel-1];
  document.getElementById('complete').classList.add('on');
}

function finishWorkout(){
  clearInterval(wTimer);
  const elapsed=Math.floor((Date.now()-wStart)/1000);
  let sets=0, reps=0;
  document.querySelectorAll('.ex-card2').forEach(card=>{
    card.querySelectorAll('.set-row').forEach(row=>{
      const fields=row.querySelectorAll('.set-field');
      const r=parseFloat(fields[0]?.value)||0, k=parseFloat(fields[1]?.value)||0;
      if(r>0) sets++;
      reps+=r;
    });
  });
  const sessName=document.getElementById('wk-title').textContent;
  const w={id:Date.now(),date:new Date().toISOString(),type:'weights',name:sessName,duration:elapsed,reps,sets};
  workouts.unshift(w); SAVE('workouts',workouts);
  if(activeProgKey){ markSessionDone(activeProgKey.phaseIdx,activeProgKey.weekIdx,activeProgKey.sessIdx); activeProgKey=null; }
  document.getElementById('rest-bar').classList.remove('on');
  document.getElementById('c-emoji').textContent='🏆';
  document.getElementById('c-dur').textContent=fmt(elapsed);
  document.getElementById('c-sets').textContent=sets+' sets';
  document.getElementById('c-vol').textContent=reps+' reps';
  document.getElementById('c-sub').textContent=sessName+' bouclée 💪';
  document.getElementById('complete').classList.add('on');
}

